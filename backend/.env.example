# Server Configuration
PORT=3001

# Ollama Configuration
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.1

# Salesforce Configuration (Get these from your Salesforce Developer Org)
# 1. Create a Salesforce Developer account at https://developer.salesforce.com
# 2. Create a new Connected App in Setup > App Manager
# 3. Get your instance URL and access token

# Your Salesforce instance URL (e.g., https://yourinstance.salesforce.com)
SALESFORCE_INSTANCE_URL=https://your-instance.salesforce.com


SALESFORCE_CONSUMER_KEY=your_consumer_key_here

# OAuth Consumer Secret from Connected App
SALESFORCE_CONSUMER_SECRET=your_consumer_secret_here

# Access Token (you can get this from OAuth flow or create a connected app with refresh token)
SALESFORCE_ACCESS_TOKEN=your_access_token_here


